generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id                    String        @id @default(cuid())
  source                String
  sourceJobId           String?       @map("source_job_id")
  title                 String
  company               String
  city                  String
  province              String
  status                String        @default("active")
  salaryMin             Int?          @map("salary_min")
  salaryMax             Int?          @map("salary_max")
  salaryText            String?       @map("salary_text")
  educationRequirement  String        @map("education_requirement")
  experienceRequirement Int?          @map("experience_requirement")
  description           String        @db.Text
  applyUrl              String        @map("apply_url") @db.Text
  publishedAt           DateTime?     @map("published_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  favorites             FavoriteJob[]
  applicationRecords    ApplicationRecord[]

  @@unique([source, sourceJobId])
  @@index([source])
  @@index([status])
  @@index([province, city])
  @@index([city])
  @@index([publishedAt])
  @@map("jobs")
}

model ApplicationRecord {
  id        String    @id @default(cuid())
  jobId     String    @map("job_id")
  userId    String?   @map("user_id")
  status    String    @default("not_applied")
  note      String?   @db.Text
  appliedAt DateTime? @map("applied_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([jobId])
  @@index([userId])
  @@index([status])
  @@index([updatedAt])
  @@map("application_records")
}

model FavoriteJob {
  id        String   @id @default(cuid())
  visitorId String   @map("visitor_id")
  userId    String?  @map("user_id")
  jobId     String   @map("job_id")
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([visitorId, jobId])
  @@unique([userId, jobId])
  @@index([visitorId])
  @@index([userId])
  @@index([jobId])
  @@map("favorite_jobs")
}

model SearchHistory {
  id                String   @id @default(cuid())
  visitorId         String?  @map("visitor_id")
  userId            String?  @map("user_id")
  educationLevel    String?  @map("education_level")
  expectedSalaryMin Int?     @map("expected_salary_min")
  expectedSalaryMax Int?     @map("expected_salary_max")
  city              String?
  keywords          String?
  experienceYears   Int?     @map("experience_years")
  source            String?
  resultCount       Int      @default(0) @map("result_count")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([visitorId])
  @@index([userId])
  @@index([city])
  @@index([createdAt])
  @@map("search_histories")
}

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  targetTitle       String?  @map("target_title")
  targetCity        String?  @map("target_city")
  expectedSalaryMin Int?     @map("expected_salary_min")
  expectedSalaryMax Int?     @map("expected_salary_max")
  education         String?
  experienceYears   Int?     @map("experience_years")
  skills            String?  @db.Text
  selfIntroduction  String?  @map("self_introduction") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_profiles")
}

model DataSource {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  type        String
  websiteUrl  String?  @map("website_url")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("data_sources")
}
